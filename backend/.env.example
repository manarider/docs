# Required environment variables — copy to .env and fill in values
NODE_ENV=production
PORT=4040

# MongoDB
MONGO_URI=mongodb://<user>:<password>@<host>:27017/docs?authSource=docs

# Redis
REDIS_URL=redis://localhost:6379

# Session Secret (สร้างด้วย: openssl rand -hex 32)
SESSION_SECRET=<replace-with-random-64-hex-chars>

# UMS (User Management System)
UMS_BASE_URL=https://nssv.nsm.go.th/ums
UMS_LOGIN_PATH=/login
UMS_PROJECT_ID=<your-project-id>
APP_CALLBACK_URL=https://app.nsm.go.th/docs/auth-callback

# CORS (คั่นด้วย comma)
CORS_ORIGIN=https://app.nsm.go.th

# File Storage
DOC_STORAGE_PATH=/data/documents
MAX_DOC_SIZE_MB=50
MAX_IMG_SIZE_MB=3
MAX_IMAGES_PER_DOC=4
